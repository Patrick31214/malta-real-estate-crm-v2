# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=malta_crm_v2
DB_USER=postgres
DB_PASSWORD=your_password_here
# Set to 'false' only if your managed PostgreSQL provider requires it (e.g. some Heroku plans)
# DB_SSL_REJECT_UNAUTHORIZED=false

# JWT (for future use)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

